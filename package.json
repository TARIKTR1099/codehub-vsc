{"name":"codehub","displayName":"CodeHub","description":"CodeHub - Terminal profilleri / Terminal profile manager","version":"1.0.0","publisher":"TARIKTR1099","engines":{"vscode":"^1.94.0"},"categories":["Other","Terminal"],"icon":"media/icon.png","activationEvents":["onStartupFinished"],"main":"./out/extension.js","contributes":{"commands":[{"command":"codehub.runDefault","title":"CodeHub: En Ustteki Profili Calistir","icon":"$(play-circle)"},{"command":"codehub.openDesktop","title":"CodeHub: OpenCode Desktop","icon":"$(browser)"},{"command":"codehub.closeAllTerminals","title":"CodeHub: Tum Terminalleri Kapat","icon":"$(trash)"},{"command":"codehub.setStatusBarProfile","title":"CodeHub: Durum Cubugu Profili Sec","icon":"$(settings)"},{"command":"codehub.setStartupProfile","title":"CodeHub: Baslangic Profili Sec","icon":"$(settings)"},{"command":"codehub.setShortcutProfile","title":"CodeHub: Kisayol Profili Sec","icon":"$(settings)"},{"command":"codehub.openSettings","title":"CodeHub: Ayarlar","icon":"$(gear)"}],"keybindings":[{"key":"ctrl+alt+t","command":"codehub.openDesktop"}],"viewsContainers":{"activitybar":[{"id":"codehub","title":"CodeHub","icon":{"dark":"media/activity-icon-dark.svg","light":"media/activity-icon-light.svg"}}]},"views":{"codehub":[{"type":"webview","id":"codehub.sidePanel","name":"CodeHub"}]},"configuration":{"title":"CodeHub","properties":{"codehub.terminalProfiles":{"type":"array","default":[],"items":{"type":"object","properties":{"id":{"type":"string"},"name":{"type":"string"},"icon":{"type":"string"},"shell":{"type":"string","enum":["powershell","cmd","wsl","bash","zsh","custom"]},"shellPath":{"type":"string"},"commands":{"type":"array","items":{"type":"string"}},"openIn":{"type":"string","enum":["cli","desktop","vscode"]}}},"description":"Terminal profilleri / Terminal profiles"},"codehub.defaultProfile":{"type":"string","default":"","description":"Varsayilan profil IDsi (bos = en ustteki) / Default profile ID (empty = topmost)"},"codeh